# IBKR credentials
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# paper or live
TRADING_MODE=paper

# Port: 4004 = paper socat relay, 4003 = live socat relay (bypasses TrustedIPs)
IBKR_PORT=4004
IBKR_CLIENT_ID=1

# Position sizing — size trades as if account is this value
# regardless of actual broker equity (e.g. 10000 for $10k sizing)
ACCOUNT_SIZE=10000

# Massive.com API key (leave empty to use yfinance fallback)
MASSIVE_API_KEY=

# Telegram alerts (leave empty to disable)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Set to true to scan full S&P 500 instead of curated 42-stock universe
USE_FULL_SP500=false
